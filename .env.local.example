# Database (Railway PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Redis (Railway Redis)
REDIS_URL="redis://default:password@host:6379"

# JWT Auth
JWT_SECRET="your-64-char-random-secret-here-change-in-production-!!!!"

# Encryption key for stored API keys (32 bytes hex = 64 chars)
ENCRYPTION_KEY="your-64-char-hex-encryption-key-here-change-in-production"

# Initial super-admin credentials (used by prisma/seed.ts)
SUPER_ADMIN_USERNAME="admin"
SUPER_ADMIN_PASSWORD="change-me-in-production"
SUPER_ADMIN_NAME="Super Admin"

# App URL (used in AI HTTP-Referer header)
APP_URL="http://localhost:3000"
