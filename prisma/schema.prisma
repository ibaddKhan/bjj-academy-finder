// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  super_admin
  member
}

enum JobStatus {
  queued
  running
  completed
  failed
  paused
}

enum RowStatus {
  pending
  running
  success
  error
  skipped
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  name         String
  role         Role     @default(member)
  createdAt    DateTime @default(now())

  teams         TeamMember[]
  jobs          Job[]
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// ─── Teams ────────────────────────────────────────────────────────────────────

model Team {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  members  TeamMember[]
  settings TeamSettings[]
  jobs     Job[]
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model TeamSettings {
  id     String @id @default(cuid())
  teamId String
  key    String
  value  String @db.Text // AES-256-CBC encrypted

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, key])
}

// ─── Jobs ─────────────────────────────────────────────────────────────────────

model Job {
  id           String    @id @default(cuid())
  teamId       String
  createdById  String
  templateSlug String? // null = person_finder, "gym_enrichment" = enrichment
  sheetUrl     String
  sheetId      String
  tabId        String
  tabName      String
  destSheetId  String? // enrichment: destination sheet
  destTabName  String? // enrichment: destination tab
  columnMap    Json
  status       JobStatus @default(queued)
  totalRows    Int       @default(0)
  doneRows     Int       @default(0)
  errorRows    Int       @default(0)
  createdAt    DateTime  @default(now())
  startedAt    DateTime?
  completedAt  DateTime?

  team      Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id])
  rows      JobRow[]
}

model JobRow {
  id          String    @id @default(cuid())
  jobId       String
  rowIndex    Int
  rowData     Json
  status      RowStatus @default(pending)
  attempts    Int       @default(0)
  result      Json?
  error       String?
  toolLog     Json?
  startedAt   DateTime?
  completedAt DateTime?

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([jobId, status])
}

// ─── Enrichment DB ────────────────────────────────────────────────────────────

model EventEnrichment {
  id                     String  @id @default(cuid())
  name                   String?
  name_id                String?
  email                  String?
  phone                  String?
  address                String?
  city                   String?
  state                  String?
  country                String?
  gym_academy_url        String?
  facebook               String?
  instagram              String?
  owner_person_in_charge String?
  source                 String?
  competitor             String?
  owner_instagram        String?
  coaches                String?
  owner_competing        String?
  customer               String?
  customer_status        String?
  hubspot_id             String?
  event                  String?

  @@index([name_id])
  @@map("event_enrichments")
}
